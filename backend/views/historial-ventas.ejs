<%- include('partials/head', { title: 'Historial de Ventas' }) %>
<body>
    <%- include('partials/header') %>

    <main class="container">
        <!-- Header con botón de exportar -->
        <div class="ventas-header-actions">
            <h1>Historial de Ventas</h1>
            <div class="ventas-actions-buttons">
                <a href="/admin/ventas/exportar" class="btn-exportar">
                    Exportar a Excel
                </a>
            </div>
        </div>

        <!-- Filtros -->
        <div class="ventas-filtros">
            <input type="text" id="buscar-cliente" placeholder="Buscar por cliente..." />
            <input type="date" id="fecha-inicio" />
            <input type="date" id="fecha-fin" />
            <button type="button" class="btn-filtrar" id="btn-filtrar">Filtrar</button>
            <button type="button" class="btn-limpiar" id="btn-limpiar">Limpiar</button>
        </div>

        <!-- Estadísticas -->
        <% let totalVentas=0; let totalIngresos=0; let promedio=0; let ultimaFecha='-' ; if (ventas && ventas.length> 0
            && Array.isArray(ventas)) {
            totalVentas = ventas.length;
            totalIngresos = ventas.reduce((sum, v) => {
            const precio = parseFloat(v.precioTotal) || 0;
            return sum + precio;
            }, 0);
            promedio = totalVentas > 0 ? (totalIngresos / totalVentas) : 0;

            try {
                ultimaFecha = new Date(ventas[0].fecha).toLocaleDateString('es-AR');
            } catch (e) {
                ultimaFecha = '-';
            }}
        %>
            <div class="ventas-stats">
                <div class="stat-card">
                    <div class="stat-number">
                        <%= totalVentas %>
                    </div>
                    <div class="stat-label">Total de Ventas</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">$<%= totalIngresos.toLocaleString('es-AR') %>
                    </div>
                    <div class="stat-label">Ingresos Totales</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">$<%= promedio.toFixed(2).toLocaleString('es-AR') %>
                    </div>
                    <div class="stat-label">Promedio por Venta</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">
                        <%= ultimaFecha %>
                    </div>
                    <div class="stat-label">Última Venta</div>
                </div>
            </div>

            <!-- Grilla de Ventas -->
            <% if (ventas && ventas.length> 0) { %>
                <div class="ventas-grid" id="ventas-grid">
                    <% ventas.forEach(venta=> {
                        const fecha = new Date(venta.fecha);
                        const fechaFormateada = fecha.toLocaleDateString('es-AR', {
                        day: '2-digit',
                        month: '2-digit',
                        year: 'numeric',
                        hour: '2-digit',
                        minute: '2-digit'
                        });
                        %>
                        <div class="venta-card">
                            <div class="venta-header">
                                <span class="venta-id">#<%= venta.id %></span>
                                <span class="venta-fecha">
                                    <%= fechaFormateada %>
                                        <span class="badge">
                                            <%= venta.productos ? venta.productos.length : 0 %> productos
                                        </span>
                                </span>
                            </div>

                            <div class="venta-body">
                                <div class="venta-cliente">
                                    <span class="label">Cliente</span>
                                    <span class="value">
                                        <%= venta.nombreCliente || 'Anónimo' %>
                                    </span>
                                </div>

                                <div class="venta-productos">
                                    <span class="label">Productos</span>
                                    <ul>
                                        <% if (venta.productos && venta.productos.length> 0) { %>
                                            <% venta.productos.forEach(prod=> { %>
                                                <li>
                                                    <span>
                                                        <%= prod.productoNombre %>
                                                    </span>
                                                    <span>
                                                        <span class="cantidad">x<%= prod.cantidad %></span>
                                                        <span class="subtotal">$<%= (prod.cantidad *
                                                                prod.precioUnitario).toLocaleString() %></span>
                                                    </span>
                                                </li>
                                                <% }) %>
                                                    <% } else { %>
                                                        <li style="color: #94a3b8; font-style: italic;">Sin
                                                            productos</li>
                                                        <% } %>
                                    </ul>
                                </div>

                                <div class="venta-total">
                                    <span class="label">Total</span>
                                    <span class="value">
                                        $<%= venta.precioTotal.toLocaleString() %>
                                            <small>ARS</small>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                </div>

                <!-- Paginación -->
                <div class="pagination">
                    <button type="button" class="pagina-btn" id="pagina-anterior">Anterior</button>
                    <span class="active">1</span>
                    <button type="button" class="pagina-btn">2</button>
                    <button type="button" class="pagina-btn">3</button>
                    <button type="button" class="pagina-btn" id="pagina-siguiente">Siguiente</button>
                </div>

                <% } else { %>
                    <div class="empty-message">
                        <h3>No hay ventas registradas</h3>
                        <p>Todavía no se realizaron ventas en el sistema.</p>
                        <p style="margin-top: 12px; font-size: 13px;">
                            Podés registrar una venta desde el <a href="/admin/dashboard">Dashboard</a>
                        </p>
                    </div>
                    <% } %>
    </main>

    <script>
        // ============================================
        // FILTROS
        // ============================================
        const btnFiltrar = document.getElementById('btn-filtrar');
        const btnLimpiar = document.getElementById('btn-limpiar');
        const buscarCliente = document.getElementById('buscar-cliente');
        const fechaInicio = document.getElementById('fecha-inicio');
        const fechaFin = document.getElementById('fecha-fin');

        function aplicarFiltros() {
            const busqueda = buscarCliente.value.toLowerCase().trim();
            const inicio = fechaInicio.value;
            const fin = fechaFin.value;
            const cards = document.querySelectorAll('.venta-card');
            let visibles = 0;

            cards.forEach(card => {
                const cliente = card.querySelector('.venta-cliente .value')?.textContent?.toLowerCase() || '';
                const fechaCard = card.querySelector('.venta-header .venta-fecha')?.textContent || '';

                // Filtro por cliente
                let coincideCliente = cliente.includes(busqueda);

                // Filtro por fecha (básico)
                let coincideFecha = true;
                if (inicio && fechaCard) {
                    // Simplificado: solo filtro por cliente, podés expandir con fecha
                }

                const mostrar = coincideCliente && coincideFecha;
                card.style.display = mostrar ? 'block' : 'none';
                if (mostrar) visibles++;
            });

            // Mostrar mensaje si no hay resultados
            const mensajeVacio = document.getElementById('sin-resultados');
            if (visibles === 0 && cards.length > 0) {
                if (!mensajeVacio) {
                    const grid = document.getElementById('ventas-grid');
                    const msg = document.createElement('div');
                    msg.id = 'sin-resultados';
                    msg.className = 'empty-message';
                    msg.innerHTML = `
                        <h3>No hay resultados</h3>
                        <p>No se encontraron ventas con los filtros aplicados.</p>
                    `;
                    grid.parentNode.insertBefore(msg, grid.nextSibling);
                }
            } else if (mensajeVacio) {
                mensajeVacio.remove();
            }
        }

        function limpiarFiltros() {
            buscarCliente.value = '';
            fechaInicio.value = '';
            fechaFin.value = '';
            document.querySelectorAll('.venta-card').forEach(c => c.style.display = 'block');
            const mensajeVacio = document.getElementById('sin-resultados');
            if (mensajeVacio) mensajeVacio.remove();
        }

        btnFiltrar?.addEventListener('click', aplicarFiltros);
        btnLimpiar?.addEventListener('click', limpiarFiltros);

        // Filtrar al presionar Enter
        buscarCliente?.addEventListener('keyup', function (e) {
            if (e.key === 'Enter') aplicarFiltros();
        });

        // ============================================
        // PAGINACIÓN (funcionalidad básica)
        // ============================================
        // (Opcional: podés implementar paginación real con backend)
    </script>
</body>

</html>