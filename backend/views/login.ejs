<%- include('partials/head', { title: 'Iniciar Sesión' }) %>
<body>
    <%- include('partials/header') %>

    <main class="login-container">
        <div class="login-card">
            <h1>Iniciar Sesión</h1>
            <p class="subtitle">Panel de Administración</p>

            <!-- El formulario envía los datos vía POST a la misma ruta de login -->
            <form action="/admin/login" method="POST" class="login-form">
                <div class="form-group">
                    <label for="correo">Correo Electrónico</label>
                    <input type="email" id="correo" name="correo" placeholder="admin@ejemplo.com" required>
                </div>

                <div class="form-group">
                    <label for="contrasena">Contraseña</label>
                    <input type="password" id="contrasena" name="contrasena" placeholder="••••••••" required>
                </div>

                <button type="submit" class="btn btn-primary">Ingresar</button>
            </form>

            <div class="divider">o bien</div>

            <!-- ✅ NUEVO: Link a registro -->
            <p class="text-center">
                ¿No tenés cuenta? <a href="/admin/register" class="link-register">Registrarse</a>
            </p>

            <!-- Botón de Acceso Rápido -->
            <button type="button" id="btn-quick-access" class="btn btn-secondary">
                Acceso Rápido (Tester)
            </button>
        </div>
    </main>

    <!-- Script de frontend para interactuar con la interfaz de forma dinámica -->
    <script>
        document.getElementById('btn-quick-access').addEventListener('click', () => {
            document.getElementById('correo').value = 'admin@autoservicio.com';
            // Le ponemos la contraseña que configuraste en tu base de datos local
            document.getElementById('contrasena').value = 'castellanosaulo';
        });
    </script>
</body>
</html>